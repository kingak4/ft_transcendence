# What to put in .env.local — depends on where you run commands from:
#
#  ┌─────────────────────────────┬──────────────────────────────────┬──────────────────────────────────────────────────────────────┐
#  │           Scenario          │    value to use for .env.local   │                           Why                                │
#  ├─────────────────────────────┼──────────────────────────────────┼──────────────────────────────────────────────────────────────┤
#  │ Devcontainer (VS Code       │ http://localhost:5001            │ devcontainer.json uses --network=host, so the container      │
#  │ Dev Containers)             │                                  │ shares the host network stack. localhost:5001 reaches the    │
#  │                             │                                  │ backend's published port exactly as it would from the host.  │
#  ├─────────────────────────────┼──────────────────────────────────┼──────────────────────────────────────────────────────────────┤
#  │ Host terminal (plain        │ http://localhost:5001            │ Running natively — port 5001 is published to the host        │
#  │ WSL / Linux)                │                                  │ loopback by Docker.                                          │
#  ├─────────────────────────────┼──────────────────────────────────┼──────────────────────────────────────────────────────────────┤
#  │ Remote machine              │ http://<machine-ip>:5001         │ Must route over the network to reach the other machine.      │
#  └─────────────────────────────┴──────────────────────────────────┴──────────────────────────────────────────────────────────────┘

BACKEND_URL=http://transcend-backend:5000

# Browser-side WebSocket URL for STOMP (must be NEXT_PUBLIC_ so it gets embedded in the JS bundle).
# The backend uses SockJS, which opens with an HTTP negotiation — use http:// not ws://.
# For local dev (.env.local): http://localhost:5001/ws
# For Docker via nginx (.env):  https://localhost:8443/ws  (nginx terminates TLS, proxies as plain ws:// internally)
NEXT_PUBLIC_WS_URL=http://localhost:5001/ws
