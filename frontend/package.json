{
  "name": "ft_transcendence",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "generate:api": ". ./.env && openapi-typescript ${BACKEND_URL}/api-docs -o app/types/api.d.ts",
    "generate:api:dev": ". ./.env.local && openapi-typescript ${BACKEND_URL}/api-docs -o app/types/api.d.ts",
    "generate:asyncapi": ". ./.env && BACKEND_URL=${BACKEND_URL} node scripts/generate-asyncapi.mjs",
    "generate:asyncapi:dev": ". ./.env.local && BACKEND_URL=${BACKEND_URL} node scripts/generate-asyncapi.mjs",
    "generate:all": "npm run generate:api && npm run generate:asyncapi",
    "generate:all:dev": "npm run generate:api:dev && npm run generate:asyncapi:dev"
  },
  "dependencies": {
    "@stomp/stompjs": "^7.0.0",
    "next": "^16.2.6",
    "openapi-fetch": "^0.17.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-stomp-hooks": "^3.0.0",
    "sockjs-client": "^1.6.1"
  },
  "devDependencies": {
    "@asyncapi/modelina": "^3.0.0",
    "@asyncapi/parser": "^3.0.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sockjs-client": "^1.5.4",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "eslint-plugin-tailwindcss": "^3.18.3",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "jsonpath-plus": "^10.3.0",
    "postcss": "^8.5.10"
  }
}
